# Google AI Studio API key for Gemini models used by the ADK agents.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Tells the ADK to use the Google AI Studio backend (not Vertex AI).
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Optional: model the agents run on.
SECUREGUARD_MODEL=gemini-2.0-flash

# Optional: least-privilege GitHub token, used ONLY if PR creation is enabled.
# Scope it to a single repo with `pull_request` write access — nothing more.
GITHUB_TOKEN=
